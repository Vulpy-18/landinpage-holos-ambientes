<!doctype html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>
      O DNA dos Espaços — Mentoria Apometria de Ambientes | Flávio Rodrigues
    </title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Playfair+Display:ital,wght@0,400;0,500;0,600;0,700;1,500&family=Jost:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400&display=swap"
      rel="stylesheet"
    />

    <style>
      :root {
        --teal-deep: #0b3d3f;
        --teal: #135c5f;
        --teal-mid: #1f7a80;
        --aqua: #4fb8ae;
        --aqua-soft: #cfe9e4;
        --aqua-wash: #f1f8f6;
        --gold: #b8912e;
        --gold-bright: #d4af37;
        --gold-soft: rgba(184, 145, 46, 0.14);
        --violet: #8b7cc4;
        --violet-soft: rgba(139, 124, 196, 0.12);
        --cream: #faf8f4;
        --ink: #0e2b2c;
        --ink-soft: rgb(14, 43, 44);
        --ink-faint: rgb(14, 43, 44);
        --line: rgba(14, 43, 44, 0.1);
        --white: #ffffff;

        --ff-display: "Playfair Display", serif;
        --ff-body: "Jost", sans-serif;

        --radius: 2px;
        --ease: cubic-bezier(0.4, 0, 0.2, 1);
      }

      * {
        margin: 0;
        padding: 0;
        box-sizing: border-box;
      }
      html {
        scroll-behavior: smooth;
      }
      body {
        font-family: var(--ff-body);
        background: var(--cream);
        color: var(--ink);
        line-height: 1.7;
        overflow-x: hidden;
        -webkit-font-smoothing: antialiased;
      }

      .container {
        width: min(92%, 1080px);
        margin-inline: auto;
      }
      .container-narrow {
        width: min(92%, 720px);
        margin-inline: auto;
      }
      .container img {
        width: 200px;
        height: 200px;
      }
      section {
        padding-block: clamp(64px, 9vw, 128px);
        position: relative;
      }

      h1,
      h2,
      h3,
      h4 {
        font-family: var(--ff-display);
        font-weight: 500;
        line-height: 1.18;
        color: var(--teal-deep);
      }
      h2 {
        font-size: clamp(1.9rem, 4vw, 2.9rem);
      }
      h3 {
        font-size: clamp(1.25rem, 2.4vw, 1.6rem);
      }
      p {
        color: var(--ink-soft);
        font-weight: 300;
      }
      em {
        font-style: italic;
        color: var(--gold);
      }

      .eyebrow {
        display: flex;
        align-items: center;
        gap: 12px;
        justify-content: center;
        font-family: var(--ff-body);
        font-size: 0.72rem;
        letter-spacing: 0.32em;
        text-transform: uppercase;
        color: var(--gold);
        margin-bottom: 20px;
      }
      .eyebrow::before,
      .eyebrow::after {
        content: "";
        width: 28px;
        height: 1px;
        background: var(--gold);
        opacity: 0.6;
      }
      .eyebrow.left {
        justify-content: flex-start;
      }
      .eyebrow.left::before {
        display: none;
      }

      .text-center {
        text-align: center;
      }

      /* reveal */
      .reveal {
        opacity: 0;
        transform: translateY(28px);
        transition:
          opacity 0.8s var(--ease),
          transform 0.8s var(--ease);
      }
      .reveal.visible {
        opacity: 1;
        transform: translateY(0);
      }
      /* ============================================================
       CTA BUTTONS
    ============================================================ */
      .btn {
        display: inline-flex;
        align-items: center;
        gap: 10px;
        padding: 16px 38px;
        font-family: var(--ff-body);
        font-size: 0.78rem;
        font-weight: 500;
        letter-spacing: 0.18em;
        text-transform: uppercase;
        text-decoration: none;
        border-radius: var(--radius);
        cursor: pointer;
        transition: all 0.35s var(--ease);
        border: 1px solid transparent;
      }
      .btn-primary {
        background: linear-gradient(120deg, var(--gold-bright), var(--gold));
        color: var(--white);
        box-shadow: 0 10px 28px rgba(184, 145, 46, 0.28);
      }
      .btn-primary:hover {
        transform: translateY(-2px);
        box-shadow: 0 14px 36px rgba(184, 145, 46, 0.38);
      }
      .btn-outline {
        background: transparent;
        color: var(--teal-deep);
        border-color: var(--teal-deep);
      }
      .btn-outline:hover {
        background: var(--teal-deep);
        color: var(--white);
      }

      /* ============================================================
       HERO
    ============================================================ */
      #hero {
        min-height: 100svh;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding-top: 120px;
        background:
          radial-gradient(
            ellipse 60% 30% at 50% 0%,
            var(--aqua-wash) 0%,
            transparent 60%
          ),
          radial-gradient(
            ellipse 50% 40% at 85% 90%,
            var(--violet-soft) 0%,
            transparent 60%
          ),
          var(--white);
      }
      .hero-badge {
        font-family: var(--ff-body);
        font-size: 0.7rem;
        letter-spacing: 0.3em;
        text-transform: uppercase;
        color: var(--teal-mid);
        border: 1px solid var(--aqua-soft);
        background: var(--white);
        padding: 8px 20px;
        border-radius: 40px;
        margin-bottom: 36px;
      }
      #hero h1 {
        max-width: auto;
        font-size: clamp(2.3rem, 5.4vw, 4.1rem);
        margin-bottom: 22px;
      }
      #hero h1 .veil {
        display: block;
        font-family: var(--ff-display);
        font-style: italic;
        font-weight: 400;
        font-size: 0.44em;
        color: var(--gold);
        margin-top: 10px;
      }
      .hero-sub {
        max-width: auto;
        font-size: clamp(1rem, 1.6vw, 1.15rem);
        color: var(--ink-soft);
        margin-bottom: 44px;
      }
      .hero-ctas {
        display: flex;
        flex-wrap: wrap;
        gap: 16px;
        justify-content: center;
        margin-bottom: 56px;
      }
      .hero-stats {
        display: flex;
        gap: clamp(28px, 6vw, 64px);
        flex-wrap: wrap;
        justify-content: center;
      }
      .hero-stat {
        text-align: center;
      }
      .hero-stat strong {
        display: block;
        font-family: var(--ff-display);
        font-size: 2rem;
        color: var(--teal-deep);
      }
      .hero-stat span {
        font-size: 0.7rem;
        letter-spacing: 0.14em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }

      /* ============================================================
       DIVIDER
    ============================================================ */
      .divider {
        display: flex;
        align-items: center;
        gap: 14px;
        max-width: 420px;
        margin: 0 auto;
      }
      .divider .line {
        flex: 1;
        height: 1px;
        background: linear-gradient(
          90deg,
          transparent,
          var(--aqua-soft),
          transparent
        );
      }
      .divider .dot {
        width: 6px;
        height: 6px;
        border-radius: 50%;
        background: var(--gold);
      }

      /* ============================================================
       PROBLEMA
    ============================================================ */
      #problema {
        background: var(--teal-deep);
        color: var(--white);
      }
      #problema h2 {
        color: var(--white);
      }
      #problema .eyebrow {
        color: var(--gold-bright);
      }
      #problema .eyebrow::before,
      #problema .eyebrow::after {
        background: var(--gold-bright);
      }
      #problema p {
        color: rgba(255, 255, 255, 0.72);
      }
      .dor-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
        gap: 2px;
        margin-top: 52px;
        background: rgba(255, 255, 255, 0.08);
      }
      .dor-card {
        background: var(--teal-deep);
        padding: 34px 28px;
        border-top: 2px solid var(--gold-bright);
      }
      .dor-card h4 {
        font-family: var(--ff-display);
        font-size: 1.1rem;
        color: var(--white);
        font-weight: 500;
        margin-bottom: 10px;
      }
      .dor-card p {
        font-size: 0.92rem;
        color: rgba(255, 255, 255, 0.65);
      }

      /* ============================================================
       TRANSFORMAÇÃO / SOLUÇÃO
    ============================================================ */
      #transformacao {
        background: var(--cream);
      }
      .transf-quote {
        max-width: 780px;
        margin: 40px auto 0;
        text-align: center;
        font-family: var(--ff-display);
        font-style: italic;
        font-size: clamp(1.35rem, 2.8vw, 1.85rem);
        line-height: 1.6;
        color: var(--teal-deep);
      }
      .transf-quote span {
        color: var(--gold);
      }

      /* ============================================================
       SOBRE A MENTORIA — cards de estrutura
    ============================================================ */
      #estrutura {
        background: var(--aqua-wash);
      }
      .estrutura-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
        gap: 24px;
        margin-top: 52px;
      }
      .estrutura-card {
        background: var(--white);
        padding: 34px 26px;
        border: 1px solid var(--line);
        text-align: center;
        transition: all 0.35s var(--ease);
      }
      .estrutura-card:hover {
        border-color: var(--gold);
        transform: translateY(-4px);
        box-shadow: 0 16px 40px rgba(14, 43, 44, 0.08);
      }
      .estrutura-icon {
        width: 44px;
        height: 44px;
        margin: 0 auto 18px;
        color: var(--teal-mid);
      }
      .estrutura-card h4 {
        font-family: var(--ff-display);
        font-size: 1.05rem;
        margin-bottom: 8px;
      }
      .estrutura-card p {
        font-size: 0.88rem;
      }
      .bonus-strip {
        margin-top: 44px;
        background: var(--teal-deep);
        color: var(--white);
        padding: 30px 36px;
        display: flex;
        align-items: center;
        gap: 24px;
        flex-wrap: wrap;
        justify-content: space-between;
      }
      .bonus-strip .tag {
        display: inline-block;
        font-size: 0.65rem;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--teal-deep);
        background: var(--gold-bright);
        padding: 5px 14px;
        margin-bottom: 8px;
      }
      .bonus-strip h4 {
        color: var(--white);
        font-size: 1.15rem;
        font-weight: 500;
      }
      .bonus-strip p {
        color: rgba(255, 255, 255, 0.68);
        font-size: 0.9rem;
        max-width: 480px;
      }

      /* ============================================================
       MÓDULOS — timeline vertical (6 encontros)
    ============================================================ */
      #modulos {
        background: var(--cream);
      }
      .timeline {
        position: relative;
        margin-top: 56px;
        padding-left: 46px;
      }
      .timeline::before {
        content: "";
        position: absolute;
        left: 13px;
        top: 6px;
        bottom: 6px;
        width: 1px;
        background: linear-gradient(180deg, var(--gold), var(--aqua-soft) 90%);
      }
      .timeline-item {
        position: relative;
        margin-bottom: 6px;
        cursor: pointer;
      }
      .timeline-item::before {
        content: "";
        position: absolute;
        left: -46px;
        top: 6px;
        width: 12px;
        height: 12px;
        border-radius: 50%;
        background: var(--cream);
        border: 2px solid var(--gold);
        transition: all 0.3s var(--ease);
      }
      .timeline-item.open::before {
        background: var(--gold);
      }
      .timeline-head {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 18px;
        padding: 20px 24px;
        background: var(--white);
        border: 1px solid var(--line);
        transition: all 0.3s var(--ease);
      }
      .timeline-item.open .timeline-head,
      .timeline-head:hover {
        border-color: var(--aqua-soft);
        box-shadow: 0 10px 28px rgba(14, 43, 44, 0.06);
      }
      .timeline-head-text .num {
        font-family: var(--ff-body);
        font-size: 0.68rem;
        letter-spacing: 0.2em;
        color: var(--gold);
        text-transform: uppercase;
      }
      .timeline-head-text h3 {
        margin-top: 4px;
        font-size: 1.05rem;
      }
      .timeline-toggle {
        width: 30px;
        height: 30px;
        border-radius: 50%;
        border: 1px solid var(--line);
        display: flex;
        align-items: center;
        justify-content: center;
        color: var(--teal-mid);
        flex-shrink: 0;
        transition: transform 0.3s var(--ease);
      }
      .timeline-item.open .timeline-toggle {
        transform: rotate(45deg);
        border-color: var(--gold);
        color: var(--gold);
      }
      .timeline-body {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.4s var(--ease);
      }
      .timeline-body-inner {
        overflow: hidden;
      }
      .timeline-item.open .timeline-body {
        grid-template-rows: 1fr;
      }
      .timeline-body p {
        padding: 20px 24px 26px;
        font-size: 0.92rem;
        margin-top: -4px;
        background: var(--aqua-wash);
        border-inline: 1px solid var(--line);
        border-bottom: 1px solid var(--line);
      }

      /* ============================================================
       SOBRE O MENTOR
    ============================================================ */
      #mentor {
        background: var(--teal-deep);
        color: var(--white);
      }
      .mentor-grid {
        display: grid;
        grid-template-columns: 0.85fr 1.15fr;
        gap: 60px;
        align-items: center;
        margin-top: 20px;
      }
      @media (max-width: 820px) {
        .mentor-grid {
          grid-template-columns: 1fr;
        }
      }
      .mentor-visual {
        position: relative;
        aspect-ratio: 1 / 1;
        max-width: 340px;
        margin-inline: auto;
        display: flex;
        align-items: center;
        justify-content: center;
      }
      .mentor-visual img {
        width: 800px;
        height: 600px;
      }
      .mentor-name {
        font-family: var(--ff-display);
        font-size: clamp(1.6rem, 3vw, 2.1rem);
        color: var(--white);
        margin-bottom: 6px;
      }
      .mentor-role {
        font-size: 0.7rem;
        letter-spacing: 0.24em;
        text-transform: uppercase;
        color: var(--gold-bright);
        margin-bottom: 22px;
      }
      #mentor p {
        color: rgba(255, 255, 255, 0.72);
        font-size: 0.98rem;
      }
      #mentor p + p {
        margin-top: 14px;
      }
      .mentor-badge {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        margin-top: 26px;
        font-size: 0.7rem;
        letter-spacing: 0.16em;
        text-transform: uppercase;
        color: var(--gold-bright);
        border: 1px solid rgba(212, 175, 55, 0.4);
        padding: 8px 18px;
        border-radius: 40px;
      }

      /* ============================================================
       PROVA SOCIAL
    ============================================================ */
      /* Grade de depoimentos */
      .depo-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 24px;
        margin-top: 56px;
        text-align: left;
      }

      /* Card individual */
      .depo-card {
        background: var(--white);
        border: 1px solid var(--line);
        border-radius: var(--radius);
        overflow: hidden;
        box-shadow: 0 4px 12px rgba(14, 43, 44, 0.04);
        transition:
          transform 0.3s var(--ease),
          box-shadow 0.3s var(--ease),
          border-color 0.3s var(--ease);
        display: flex;
        flex-direction: column;
      }
      .depo-card:hover {
        transform: translateY(-4px);
        box-shadow: 0 16px 32px rgba(14, 43, 44, 0.08);
        border-color: var(--gold);
      }

      /* Container para imagens e vídeos */
      .depo-media {
        width: 100%;
        border-bottom: 1px solid var(--line);
        background: var(--aqua-wash);
      }
      .depo-media img {
        width: 100%;
        height: auto;
        display: block;
        object-fit: cover;
        max-height: 220px;
      }

      /* Wrapper responsivo para iframe de vídeo (mantém a proporção 16:9) */
      .video-wrapper {
        position: relative;
        padding-bottom: 56.25%; /* Proporção 16:9 */
        height: 0;
        overflow: hidden;
      }
      .video-wrapper iframe,
      .video-wrapper video {
        position: absolute;
        top: 0;
        left: 0;
        width: 100%;
        height: 100%;
      }

      /* Textos do depoimento */
      .depo-content {
        padding: 24px;
        flex-grow: 1; /* Faz o card empurrar o autor lá pra baixo se o texto for curto */
        display: flex;
        flex-direction: column;
        justify-content: space-between;
      }
      .depo-text {
        font-family: var(--ff-display);
        font-style: italic;
        font-size: 1rem;
        color: var(--ink-soft);
        margin-bottom: 20px;
        line-height: 1.5;
      }

      /* Assinatura do autor */
      .depo-author {
        font-family: var(--ff-body);
        font-size: 0.8rem;
        color: var(--teal-mid);
        border-top: 1px solid var(--line);
        padding-top: 14px;
        margin-top: auto; /* Joga a assinatura pro fim do card */
      }
      .depo-author strong {
        color: var(--teal-deep);
        font-weight: 500;
      }

      #prova {
        background: var(--aqua-wash);
        text-align: center;
      }
      .prova-number {
        font-family: var(--ff-display);
        font-size: clamp(3rem, 8vw, 5.2rem);
        color: var(--teal-deep);
        line-height: 1;
      }
      .prova-number span {
        color: var(--gold);
      }
      .prova-label {
        margin-top: 10px;
        font-size: 0.78rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: var(--ink-faint);
      }
      .prova-note {
        max-width: 560px;
        margin: 40px auto 0;
        font-style: italic;
        font-family: var(--ff-display);
        font-size: 1.15rem;
        color: var(--teal-deep);
      }
      .depo-empty {
        max-width: 640px;
        margin: 48px auto 0;
        padding: 40px;
        border: 1px dashed var(--aqua-soft);
        background: var(--white);
      }
      .depo-empty p {
        font-family: var(--ff-display);
        font-style: italic;
        color: var(--ink-faint);
      }

      /* ============================================================
       OFERTA
    ============================================================ */
      #oferta {
        background: linear-gradient(160deg, var(--teal-deep) 0%, #0a2f30 100%);
        color: var(--white);
        text-align: center;
      }
      #oferta .eyebrow {
        color: var(--gold-bright);
      }
      #oferta .eyebrow::before,
      #oferta .eyebrow::after {
        background: var(--gold-bright);
      }
      #oferta h2 {
        color: var(--white);
        max-width: 640px;
        margin-inline: auto;
      }
      #oferta > .container > p.lead {
        max-width: 560px;
        margin: 18px auto 48px;
        color: rgba(255, 255, 255, 0.72);
      }
      .oferta-card {
        max-width: 640px;
        margin-inline: auto;
        background: rgba(255, 255, 255, 0.04);
        border: 1px solid rgba(212, 175, 55, 0.3);
        padding: clamp(30px, 5vw, 52px);
      }
      .oferta-list {
        list-style: none;
        text-align: left;
        display: flex;
        flex-direction: column;
        gap: 14px;
        margin-bottom: 36px;
      }
      .oferta-list li {
        display: flex;
        gap: 12px;
        align-items: flex-start;
        font-size: 0.95rem;
        color: rgba(255, 255, 255, 0.85);
      }
      .oferta-list li::before {
        content: "✦";
        color: var(--gold-bright);
        flex-shrink: 0;
        margin-top: 2px;
      }
      .oferta-note {
        margin-top: 22px;
        font-size: 0.75rem;
        letter-spacing: 0.08em;
        color: rgba(255, 255, 255, 0.45);
      }

      /* ============================================================
       FAQ
    ============================================================ */
      #faq {
        background: var(--cream);
      }
      .faq-list {
        max-width: 760px;
        margin: 48px auto 0;
        border-top: 1px solid var(--line);
      }
      .faq-item {
        border-bottom: 1px solid var(--line);
      }
      .faq-q {
        width: 100%;
        background: none;
        border: none;
        text-align: left;
        padding: 22px 4px;
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 16px;
        cursor: pointer;
        font-family: var(--ff-display);
        font-size: 1.02rem;
        color: var(--teal-deep);
      }
      .faq-q .plus {
        flex-shrink: 0;
        width: 22px;
        height: 22px;
        border-radius: 50%;
        border: 1px solid var(--gold);
        color: var(--gold);
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        transition: transform 0.3s var(--ease);
      }
      .faq-item.active .plus {
        transform: rotate(45deg);
      }
      .faq-a {
        max-height: 0;
        overflow: hidden;
        transition: max-height 0.4s var(--ease);
      }
      .faq-a.open {
        max-height: 300px;
      }
      .faq-a p {
        padding: 0 4px 22px;
        font-size: 0.92rem;
      }

      /* ============================================================
       CTA FINAL
    ============================================================ */
      #cta-final {
        background: var(--white);
        text-align: center;
      }
      #cta-final .divider {
        margin-bottom: 30px;
      }
      #cta-final p.lead {
        max-width: 500px;
        margin: 16px auto 40px;
      }

      /* ============================================================
       FOOTER — estrutura idêntica à referência, paleta nova
    ============================================================ */
      footer {
        position: relative;
        z-index: 1;
        padding: 48px 5%;
        border-top: 1px solid var(--line);
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 4px;
        text-align: center;
        background: var(--white);
      }
      footer .footer-logo {
        width: 56px;
        height: 56px;
        border-radius: 50%;
        margin-bottom: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        background: var(--teal-deep);
      }
      footer .footer-logo img {
        width: 80px;
        height: 80px;
      }
      footer p {
        font-size: 1rem;
        color: var(--ink-faint);
        margin: 0;
      }
      footer p.suporte {
        font-size: 1.4rem;
        font-weight: 300;
        letter-spacing: 0.08em;
        color: var(--ink-soft);
      }
      footer a {
        color: var(--gold);
        text-decoration: none;
      }
      footer a:hover {
        text-decoration: underline;
      }

      /* ============================================================
       RESPONSIVE
    ============================================================ */
      @media (max-width: 640px) {
        .timeline {
          padding-left: 30px;
        }
        .timeline-item::before {
          left: -30px;
        }
        .bonus-strip {
          flex-direction: column;
          align-items: flex-start;
        }
      }
    </style>
  </head>
